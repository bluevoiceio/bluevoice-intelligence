# Blue Voice — Geographic Explorer
# Copy to `.env.local` and fill in. These are SERVER-ONLY — do NOT add a
# NEXT_PUBLIC_ prefix or the secret would be inlined into the client bundle.
#
# Get the keys from Amplitude → Settings → Projects → "Blue Voice App" → General.

AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# US data center for the Blue Voice org. EU would be https://analytics.eu.amplitude.com
AMPLITUDE_BASE_URL=https://amplitude.com

# Optional: set to 1 to log one raw segmentation response (to lock the parser).
# AMPLITUDE_DEBUG=1
